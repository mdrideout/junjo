# Stable host and container ports shared by Compose and native development.
AI_CHAT_FRONTEND_PORT=26251
AI_CHAT_BACKEND_PORT=26252

# Explicit provider selection. "demo" is deterministic and credential-free.
# Select "gemini" or "grok" to use the corresponding live text and image
# adapters; a selected live provider requires its API key and never falls back.
AI_CHAT_MODEL_PROVIDER=demo
# GEMINI_API_KEY=
# XAI_API_KEY=
# AI_CHAT_GEMINI_TEXT_MODEL=gemini-3-flash-preview
# AI_CHAT_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# AI_CHAT_GROK_TEXT_MODEL=grok-4-fast
# AI_CHAT_GROK_IMAGE_MODEL=grok-imagine-image

# The application is credential-free by default. Configure an API key only
# when exporting telemetry to a separately running local Studio instance.
# JUNJO_AI_STUDIO_API_KEY=
# JUNJO_AI_STUDIO_PORT=26155
# JUNJO_AI_STUDIO_INSECURE=true

# Debug mode exposes Studio resolver links; it never exposes the API key.
# AI_CHAT_DEBUG=true
# AI_CHAT_STUDIO_UI_URL=http://localhost:26153
