# Stable host and container ports shared by Compose and native development.
AI_CHAT_FRONTEND_PORT=26251
AI_CHAT_BACKEND_PORT=26252

# Explicit live provider selection. Missing credentials fail startup; there is
# no demo behavior or fallback provider in the product application.
AI_CHAT_MODEL_PROVIDER=gemini
# GEMINI_API_KEY=
# XAI_API_KEY=
# AI_CHAT_GEMINI_TEXT_MODEL=gemini-3.5-flash
# AI_CHAT_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# AI_CHAT_GROK_TEXT_MODEL=grok-4.3
# AI_CHAT_GROK_IMAGE_MODEL=grok-imagine-image-quality

# Configure this separate key only when exporting telemetry to Studio.
# JUNJO_AI_STUDIO_API_KEY=
# JUNJO_AI_STUDIO_PORT=26155
# JUNJO_AI_STUDIO_INSECURE=true

# Debug mode exposes Studio resolver links; it never exposes the API key.
# AI_CHAT_DEBUG=true
# AI_CHAT_STUDIO_UI_URL=http://localhost:26153
