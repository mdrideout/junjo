# The application is credential-free by default. Configure these only when
# exporting its Junjo telemetry to a local AI Studio instance.
# JUNJO_AI_STUDIO_API_KEY=
# JUNJO_AI_STUDIO_HOST=localhost
# JUNJO_AI_STUDIO_PORT=26155
# JUNJO_AI_STUDIO_INSECURE=true

# Optional application paths.
# AI_CHAT_DATA_DIRECTORY=./runtime-data
# AI_CHAT_CORS_ORIGINS=http://localhost:5173
