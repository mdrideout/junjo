---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Page not found | Junjo AI</title>
    <meta
      name="description"
      content="The requested Junjo AI page does not exist."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-junjo-ink font-sans text-white antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-3xl items-center px-6 py-20">
      <section>
        <p class="font-mono text-sm uppercase tracking-[0.14em] text-junjo-sun">
          Error 404
        </p>
        <h1 class="mt-4 text-4xl font-extrabold sm:text-5xl">Page not found</h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/75">
          The requested page may have moved as the Junjo platform documentation evolved.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/docs/"
            class="rounded-full bg-junjo-sky px-6 py-3 text-sm font-semibold text-junjo-ink transition hover:bg-junjo-cloud"
          >
            Visit the documentation
          </a>
          <a
            href="/"
            class="rounded-full border border-white/25 px-6 py-3 text-sm font-semibold transition hover:border-junjo-mint hover:text-junjo-mint"
          >
            Return to Junjo.ai
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
