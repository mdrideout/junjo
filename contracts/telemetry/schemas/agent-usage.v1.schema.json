{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://junjo.ai/contracts/telemetry/agent-usage.v1.schema.json",
  "title": "Junjo aggregate Agent usage v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "modelResponses", "fields"],
  "properties": {
    "v": {"const": 1},
    "modelResponses": {"type": "integer", "minimum": 0},
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": {"$ref": "#/$defs/aggregate"},
        "outputTokens": {"$ref": "#/$defs/aggregate"},
        "cachedInputTokens": {"$ref": "#/$defs/aggregate"},
        "reasoningTokens": {"$ref": "#/$defs/aggregate"},
        "totalTokens": {"$ref": "#/$defs/aggregate"}
      }
    }
  },
  "$defs": {
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sum", "observations"],
      "properties": {
        "sum": {"type": "integer", "minimum": 0},
        "observations": {"type": "integer", "minimum": 1}
      }
    }
  }
}
