  "adversarial_observations": [
    {
      "name": "distinct_keys_without_retry_jitter",
      "result": "fail",
      "detail": "With 100 distinct cold keys, eight refresh slots, 32 pending slots, and synchronized deterministic retry boundaries, 10 of 5,000 logical exports exhausted 10 retries. Reproducible per-exporter jitter reduced retryable UNAVAILABLE attempts from 566 to 225 and completed all 5,000 synchronized exports without raising the service memory bounds."
    }
  ],
  "interpretation": {
    "selected_default_ttl_seconds": 10,
    "reason": "The 10-second and 15-second burst candidates had equivalent cached-path performance, while the shorter candidate reduced the measured revocation bound by five seconds. Relative to no cache, the 10-second burst run increased completed export throughput by 86.6 percent and reduced retryable overload attempts by 96.4 percent.",
    "limitations": [
      "The first five runs use one shared valid API key; later exact-rate runs add shared and distinct key topologies plus synchronized and staggered timing.",
      "The two original paced runs sleep after completion; later exact-rate runs use a start-to-start schedule and should be preferred for equal offered-rate comparison.",
      "This initial evidence set did not rebuild the historical 600-second warm-cache and fresh-channel baselines; the linked pinned baseline runs provide them.",
